{
  "name": "@lappis/cg-propresenter-plugin",
  "description": "ProPresenter live-text overlay plugin for @lappis/cg-manager",
  "repository": "https://github.com/Lapplandsveckan/cg-propresenter-plugin",
  "author": "firecraftgaming <eliyah@sundstroem.com>",
  "license": "MIT",
  "version": "0.0.1",
  "main": "index.js",
  "devDependencies": {
    "@babel/core": "^7.19.3",
    "@babel/preset-env": "^7.19.3",
    "@babel/preset-typescript": "^7.18.6",
    "@eslint/js": "^9",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4",
    "eslint-plugin-react-hooks": "^5",
    "globals": "^16",
    "i18next": "^26.3.1",
    "prettier": "^3.8.3",
    "react-i18next": "^17.0.8",
    "ts-loader": "^9.2.6",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8",
    "webpack": "^5.69.0",
    "webpack-cli": "^4.9.2"
  },
  "files": [
    "dist",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "tsc": "tsc --noEmit",
    "build": "webpack",
    "watch": "webpack --watch",
    "dev": "next ./templates dev",
    "package": "cg-manager package",
    "serve": "node serve.js",
    "lint": "eslint src ui templates",
    "lint:fix": "eslint src ui templates --fix",
    "format": "prettier --write src ui templates",
    "format:check": "prettier --check src ui templates"
  },
  "cgplugin": {
    "ui": "ui",
    "steps": [
      {
        "name": "templates",
        "run": "node scripts/package-templates.js"
      }
    ]
  },
  "dependencies": {
    "@babel/preset-react": "^7.23.3",
    "@gsap/react": "^2.1.0",
    "@lappis/cg-manager": "^0.0.40",
    "@mui/icons-material": "^5.15.11",
    "@mui/material": "^5.15.11",
    "babel-loader": "^8.2.5",
    "gsap": "^3.12.5",
    "next": "^14.1.1",
    "no-try": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.1"
  }
}
